# PinPost server configuration
# Copy to .env (local dev) or set these as Railway service variables (production).

# Required ----------------------------------------------------------

# Postgres connection string. On Railway use the internal hostname
# (postgres.railway.internal) so traffic stays inside the private network.
DATABASE_URL=postgresql://user:password@host:5432/pinpost

# Long random string. Used to sign session JWTs and OAuth state.
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-me

# Public base URL of the deployed app. Used for OAuth redirects and emitted links.
APP_URL=https://pinpost-web-production.up.railway.app

# Google OAuth (login + Google Business Profile). Set up in Google Cloud Console
# under the same project as the GBP API. Authorized redirect URIs must include:
#   {APP_URL}/api/auth/google/callback
#   {APP_URL}/api/admin/gbp/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Anthropic key for AI-generated check-in descriptions.
# Without this, the "AI draft" button on the check-in screen will fail.
ANTHROPIC_API_KEY=

# Bootstrap super admin (created on first boot if no user with this email exists).
SUPER_ADMIN_EMAIL=
SUPER_ADMIN_PASSWORD=

# Optional ----------------------------------------------------------

# Set to 'production' on Railway. Enables strict CORS pinned to APP_URL.
NODE_ENV=production

# Facebook + Instagram posting. v1 ships GBP-only — leave blank to keep the
# Meta UI hidden. To enable, register a Meta app and add redirect URI:
#   {APP_URL}/api/admin/meta/callback
META_APP_ID=
META_APP_SECRET=

# Set to '1' to log DNS resolution + verbose DB diagnostics on boot.
DEBUG_DB=

# Server port. Railway injects PORT automatically; ignore unless running locally.
PORT=3001
